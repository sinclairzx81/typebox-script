{
  "name": "typebox-script",
  "displayName": "TypeBox Script",
  "description": "Syntax Highlighting for TypeBox Script Types",
  "version": "0.8.4",
  "publisher": "sinclairzx81",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sinclairzx81/typebox-script"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "typebox.script",
        "path": "./src/typebox-script.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.typescript": "typescript"
        }
      }
    ]
  }
}