{
  "scopeName": "typebox.script",
  "injectionSelector": "L:source.ts -comment -string, L:source.tsx -comment -string, L:source.js -comment -string, L:source.jsx -comment -string",
  "patterns": [
    { "include": "#typebox-script-backtick" },
    { "include": "#typebox-script-double" },
    { "include": "#typebox-script-single" }
  ],
  "repository": {
    "typebox-script-backtick": {
      "begin": "(?<![\\w$.])(?:(?:Type|t)\\.Script|Script|type|s|t)\\s*\\((?:[^`'\"]*?,\\s*)?(`)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.template.begin.ts" }
      },
      "end": "`",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.template.end.ts" }
      },
      "name": "meta.embedded.block.typescript",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        { "include": "#ts-tokens" }
      ]
    },
    "typebox-script-double": {
      "begin": "(?<![\\w$.])(?:(?:Type|t)\\.Script|Script|type|s|t)\\s*\\((?:[^`'\"]*?,\\s*)?(\")",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.ts" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.ts" }
      },
      "name": "meta.embedded.block.typescript",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        { "include": "#ts-tokens" }
      ]
    },
    "typebox-script-single": {
      "begin": "(?<![\\w$.])(?:(?:Type|t)\\.Script|Script|type|s|t)\\s*\\((?:[^`'\"]*?,\\s*)?(')",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.ts" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.ts" }
      },
      "name": "meta.embedded.block.typescript",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        { "include": "#ts-tokens" }
      ]
    },
    "ts-tokens": {
      "patterns": [
        { "include": "#ts-escaped-backtick" },
        { "include": "#ts-comment" },
        { "include": "#ts-numbers" },
        { "include": "#ts-keywords" },
        { "include": "#ts-types" },
        { "include": "#ts-strings" },
        { "include": "#ts-punctuation" }
      ]
    },
    "ts-escaped-backtick": {
      "name": "string.template.ts",
      "begin": "\\\\`",
      "end": "\\\\`",
      "patterns": [
        {
          "name": "punctuation.definition.template-expression.ts",
          "match": "\\$\\{[^}]*\\}"
        }
      ]
    },
    "ts-comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ts",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ts",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "ts-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ts",
          "match": "\\b[0-9]+n\\b"
        },
        {
          "name": "constant.numeric.ts",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.ts",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "ts-keywords": {
      "patterns": [
        {
          "name": "support.type.primitive.ts",
          "match": "\\b(string|number|boolean|symbol|bigint|object|any|unknown|void|never|null|undefined)\\b"
        },
        {
          "name": "keyword.control.ts",
          "match": "\\b(type|interface|extends|keyof|in|as|infer|readonly|typeof|import|export|from|return|const|let|var|if|else|for|while|class|implements|new|this|true|false|namespace|declare|abstract|enum|satisfies|with)\\b"
        }
      ]
    },
    "ts-types": {
      "name": "entity.name.type.ts",
      "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
    },
    "ts-strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ts",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.ts",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "ts-punctuation": {
      "patterns": [
        { "name": "punctuation.definition.block.ts", "match": "[{}]" },
        { "name": "punctuation.definition.bracket.ts", "match": "[\\[\\]]" },
        { "name": "punctuation.definition.angle.ts", "match": "[<>]" },
        { "name": "keyword.operator.ts", "match": "[|&?:=!+\\-*/%]" },
        { "name": "punctuation.terminator.ts", "match": ";" }
      ]
    }
  }
}